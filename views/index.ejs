<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Todo List: </h1> 
    <ul class="todoItems"> 
    <% for(let i=0; i < items.length; i++) {%> 
        <li class="item"> 
            <% if(items[i].completed === true) {%> 
                <span class='completed'><%= items[i].todo %></span> 
                <% }else if(items[i].deleted === true){%>
                <span.parentNode class="deleted"><%= items[i].todo %></span>
                <% }else{ %>
                    <span><%= items[i].todo %></span> 
                    <% } %>    
                    <!--An item in the Todo List-->
            <span class='fa fa-trash'></span> 
        </li>
    <% } %>
    </ul>

    <h2>Left to do: <%= left %></h2> <!--A heading for the number of tasks left to do -->

    <h2>Add A Todo:</h2> <!--A heading to add a new task -->

    <form action="/addTodo" method="POST"> <!--a form that calls the POST method linking to the addTodo route in order to add a task to the db-->
        <input type="text" placeholder="Thing To Do" name="todoItem"> <!--An input box to write in your new task, with the placeholder text "Thing To Do" -->
        <input type="submit">
    </form>
    

    <script src='js/main.js'></script> <!--This links to the client side JS file -->
</body>
</html>
